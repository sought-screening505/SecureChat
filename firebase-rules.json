{
  "rules": {
    "conversations": {
      "$conversationId": {
        "messages": {
          ".read": "auth != null",
          ".write": "auth != null",
          ".indexOn": ["createdAt"],
          "$messageId": {
            ".validate": "newData.hasChildren(['senderPublicKey', 'ciphertext', 'iv', 'messageIndex', 'createdAt'])"
          }
        }
      }
    },
    "inbox": {
      "$recipientHash": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$requestId": {
          ".validate": "newData.hasChildren(['senderPublicKey', 'senderDisplayName', 'conversationId', 'createdAt'])"
        }
      }
    },
    "accepted": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth.uid === $uid"
      }
    }
  }
}
